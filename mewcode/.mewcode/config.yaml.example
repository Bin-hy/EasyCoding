# MewCode LLM 供应商配置
# 将本文件复制为 config.yaml 并填入真实的 API 密钥
# config.yaml 已被 .gitignore 忽略，请勿提交到版本控制

providers:
  - name: "Claude"
    protocol: "anthropic"
    model: "claude-opus-4-8"
    base_url: ""        # 留空使用默认端点
    api_key: "sk-ant-..."  # 替换为真实密钥
    thinking: true       # 启用扩展思考
    context_window: 200000  # 可选，单位 token；未配置时按 protocol 默认（anthropic 200000、openai 128000）

  # - name: "OpenAI"
  #   protocol: "openai"
  #   model: "gpt-5"
  #   base_url: ""        # 留空使用默认端点，或填兼容 API 地址
  #   api_key: "sk-..."    # 替换为真实密钥
  #   # thinking: false    # OpenAI 不生效
  #   context_window: 128000  # 可选，未配置时按 protocol 默认

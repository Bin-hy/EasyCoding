# MewCode 配置
# 将本文件复制为 config.yaml 并填入真实的 API 密钥
# config.yaml 已被 .gitignore 忽略，请勿提交到版本控制
#
# ===== 项目指令文件（MEWCODE.md）=====
# 系统启动时按以下优先级加载项目指令，高优先级在前：
#   ① <project_root>/MEWCODE.md          （项目级，最高优先级）
#   ② <project_root>/.mewcode/MEWCODE.md （项目配置级）
#   ③ ~/.mewcode/MEWCODE.md              （用户级，最低优先级）
# 支持 @include 引用其他文件，嵌套深度限制 5 层，自动检测环路。
#
# ===== 会话存档 =====
# 对话历史以 JSONL 格式实时写入 .mewcode/sessions/<session_id>/conversation.jsonl
# 输入 /resume 命令可浏览和恢复历史会话
# 30 天以上的过期会话在启动时自动清理
#
# ===== 自动笔记 =====
# Agent 每 5 轮或检测到"记住"关键词时，自动提取值得记住的信息
# 笔记存储在 .mewcode/memory/（项目级）和 ~/.mewcode/memory/（用户级）
# 笔记索引自动注入后续会话的系统提示

providers:
  - name: "Claude"
    protocol: "anthropic"
    model: "claude-opus-4-8"
    base_url: ""        # 留空使用默认端点
    api_key: "sk-ant-..."  # 替换为真实密钥
    thinking: true       # 启用扩展思考
    context_window: 200000  # 可选，单位 token；未配置时按 protocol 默认（anthropic 200000、openai 128000）

  # - name: "OpenAI"
  #   protocol: "openai"
  #   model: "gpt-5"
  #   base_url: ""        # 留空使用默认端点，或填兼容 API 地址
  #   api_key: "sk-..."    # 替换为真实密钥
  #   # thinking: false    # OpenAI 不生效
  #   context_window: 128000  # 可选，未配置时按 protocol 默认
